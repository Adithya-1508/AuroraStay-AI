# --- HospitalityAI Environment Configuration Template ---
# Copy this file to '.env' in your local environment.

# 1. Databases and Caches URLs
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/hospitality
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333

# 2. Security and Authentication
JWT_SECRET=supersecretkeychangeinproduction

# 3. Model APIs and AI Providers
MODEL_PROVIDER=gemini
NVIDIA_API_KEY=your-nvidia-api-key-here
OLLAMA_URL=http://localhost:11434

# 4. Model Registry and Experiment Logging
MLFLOW_URI=http://localhost:5000

# 5. Logging and Debug Levels
LOG_LEVEL=INFO
